{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QuickMark",
  "version": "0.1.1",
  "identifier": "dev.techarm.quickmark",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "",
        "titleBarStyle": "Overlay",
        "width": 1100,
        "height": 700,
        "minWidth": 800,
        "minHeight": 500
      },
      {
        "label": "search-palette",
        "url": "index.html?window=search",
        "title": "QuickMark Search",
        "width": 640,
        "height": 172,
        "center": true,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "global-shortcut": null,
    "shell": {
      "open": true
    }
  }
}
